
@{
  ViewBag.Title = "Home Page";
}


<!--Home body content-->
<div class="home-content">
    
    <div class="home-row">
        <div class="home-logo d-flex justify-content-center my-5">
            <img src="~/Content/images/TheatreLogo.png" />
        </div>
    </div>
    
    <div class="row g-3">
        <!--Column1 Spotlight-->
        <div class="col-12 col-md-8 col-lg-8">
            <div class="home-title mb-4">
                <h3>SPOTLIGHT</h3>
            </div>
            <img src="~/Content/images/DollsHouse.png" 
                 class="img-fluid mb-4"/>
            <img src="~/Content/images/Tempest.png" 
                 class="img-fluid mb-4"/>
            <img src="~/Content/images/MidsummerNightDream.png" 
                 class="img-fluid mb-4"/>
            <img src="~/Content/images/macbeth.png" 
                 class="img-fluid mb-4"/>
        </div>
        <!--Column2 Sidebar-->
        <div class="col-12 col-md-4 col-lg-4">
            <!--Donations-->
            <div class="donations">
                <div class="home-title mb-4">
                    <h3>DONATIONS</h3>
                </div>
                <div class="btn-container">
                    <button class="btn btn-danger px-4 py-2">Click to Support</button>
                </div>
            </div>
            <div>
                <!--Sponsors-->
                <div class="home-title my-4">
                    <h3>SPONSORS</h3>
                </div>
                <div class="sponsors-container">
                    <img src="~/Content/images/Sponsors/LogoRoundColor.png" class="home-sponsors img-fluid mb-3 col-md-4 col-lg-4" />
                    <!--<img src="~/Content/images/Sponsors/Ninkasi-white-text.png" class="home-sponsors img-fluid mb-3 col-md-4 col-lg-4" />-->
                    <img src="~/Content/images/Sponsors/Ellyn-Bye-Logo.png" class="home-sponsors img-fluid mb-3 col-md-4 col-lg-4" />
                    <img src="~/Content/images/Sponsors/OCF-logo-in-white-with-tagline-lg.png" class="home-sponsors img-fluid mb-3" />
                    <img src="~/Content/images/Sponsors/RACC.png" class="home-sponsors img-fluid mb-3" />
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <!--Column1 Land Acknowledgement-->
        <div class="col-md-8 col-lg-8">
            <div class="home-title">
                <h3 class="mb-4">LAND ACKNOWLEDGEMENT</h3>
            </div>
            <div class="home-text">
                <p>Theatre Vertigo humbly acknowledges we live and work on the unceded, traditional
                tribal lands of the Multnomah, Wasco, Clackamas, Chinook bands, Kathlamet, Tualatin,
                Kalapuya, Cowlitz, Mollala, Cascades, Oregon City Tumwater, Confederated Tribes of
                the Grand Ronde and other indigenous peoples.<br /><br />
                <span style="font-weight: bold;">We are on stolen land.</span><br /><br />
                Theatre Vertigo has been and continues to examine our community relationships to ensure
                our collaborators, partners and sponsors support the our reions Indegenous Nations and communities.<br /><br />
                One of the ways Theatre Vertigo is working to act on our commitment to being of service
                to the lands that we now share is to build bridges between our arts community and local Nations.</p>
            </div>
        </div>
        <!--Column2 Link-->
        <div class="col-md-4 text-center mt-5">
            <div class="home-acknowledgement">
                <a href="https://nayapdx.org/" target="_blank"><img src="~/Content/images/NAYAFamilyCenter.jpg" class="img-fluid mt-2 col-md-8 col-lg-8"/></a>
                <div class="home-text mt-2">
                    <p>Click to visit the NAYA Family Center to learn more about supporting our local indigenous communities.</p>
                </div>
            </div>
        </div>
    </div>

</div>

    

   














